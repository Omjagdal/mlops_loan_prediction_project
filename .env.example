# ============================================
# Environment Variables Template
# ============================================

# --- Supabase (Model Artifact Storage) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_BUCKET=ml-artifacts

# --- Frontend URL (for CORS on Render) ---
FRONTEND_URL=https://your-app.vercel.app

# --- MLflow (local development only) ---
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# --- Render Deploy Hook (for CI/CD) ---
RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-xxxxx?key=xxxxx

# --- Vercel (for CI/CD) ---
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id
